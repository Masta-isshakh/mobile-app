{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler"
  },
  "include": [
    "App.tsx",
    "index.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "amplify-ui-react-native-internals.d.ts"
  ],
  "exclude": [
    "node_modules",
    "android",
    "ios",
    "amplify/node_modules"
  ]
}
